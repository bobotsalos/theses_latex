\midrule
\texttt{macd}         & $\mathbb{R}$       & EMA(12h) $-$ EMA(26h) \\
\texttt{boll\_ub}     & $\mathbb{R}$       & SMA(30h) $+ 2\,\sigma_{30}$ \\
\texttt{boll\_lb}     & $\mathbb{R}$       & SMA(30h) $- 2\,\sigma_{30}$ \\
\texttt{rsi\_30}      & $[0,100]$          & Δείκτης σχετικής ισχύος, 30 ωρών (εξομάλυνση Wilder) \\
\texttt{cci\_30}      & $\mathbb{R}$       & Δείκτης καναλιού εμπορευμάτων, 30 ωρών \\
\texttt{dx\_30}       & $[0,100]$          & Δείκτης κατεύθυνσης (DX), 30 ωρών \\

\newlabel{fig:g1-diagnostics}{{5.6}{87}{Διαγνωστικά γραφήματα μέσου όρου 5 εκτελέσεων για τον PPO-LSTM 2$\times $512 με ανταμοιβή PnL κατά την περίοδο αξιολόγησης (2024--2025). Πάνω: θέση μετρητών ανά βήμα, που αποδεικνύει ενεργή διαχείριση ρευστότητας. Κάτω: κλάσμα χαρτοφυλακίου ανά περιουσιακό στοιχείο, που αποδεικνύει συνεχή διακράτηση και περιστροφή βαρών}{figure.caption.175}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(α\anw@true \anw@print \relax )}{\ignorespaces {Μετρητά (LSTM 2$\times $512): η θέση μετρητών διακυμαίνεται ευρέως, χωρίς παρκάρισμα σε μηδέν ή στο πλήρες κεφάλαιο.}}}{87}{figure.caption.175}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(β\anw@true \anw@print \relax )}{\ignorespaces {Κλάσμα ανά περιουσιακό στοιχείο (LSTM 2$\times $512): όλα τα δέκα στοιχεία διακρατούνται σε όλη την περίοδο με συνεχώς περιστρεφόμενα βάρη.}}}{87}{figure.caption.175}\protected@file@percent }

\@writefile{lof}{\contentsline {subfigure}{\numberline{(α\anw@true \anw@print \relax )}{\ignorespaces {Κλάσμα ανά περιουσιακό στοιχείο: το BTC (πράσινο) διατηρεί σταθερή θέση $\approx 12\%$, ενώ το ATOM (πορτοκαλί) εμφανίζει απότομες αιχμές έως $\approx 30\%$ με ταχεία επαναφορά.}}}{111}{figure.caption.191}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(β\anw@true \anw@print \relax )}{\ignorespaces {Μετρητά: ενεργή διαχείριση με υψηλό πλάτος ταλάντευσης, σε πλήρη αντίθεση με τη γωνιακή λύση του πράκτορα EMA.}}}{111}{figure.caption.191}\protected@file@percent }
